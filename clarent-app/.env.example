# Clarent Environmental — clarent-app
# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# =============================================================================
# Clerk (auth)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =============================================================================
# Stripe (payments + Connect)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# =============================================================================
# Upstash Redis
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Email — Resend (transactional)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# =============================================================================
# Email — AWS SES (bulk/marketing via OrbitABM)
# =============================================================================
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1

# =============================================================================
# SMS — Twilio
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================================
# AI — Anthropic
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# n8n (workflow orchestration)
# =============================================================================
N8N_WEBHOOK_SECRET=
N8N_BASE_URL=

# =============================================================================
# EPA CDX (e-Manifest)
# =============================================================================
CDX_API_USERNAME=
CDX_API_PASSWORD=
CDX_ENVIRONMENT=test

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://app.clarent.local:3000
NEXT_PUBLIC_VENDOR_URL=http://vendors.clarent.local:3000
NEXT_PUBLIC_OPS_URL=http://ops.clarent.local:3000
NODE_ENV=development
